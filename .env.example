APP_NAME="Robert Todd Trends"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-production-domain.com

# Adobe Fonts (Typekit) — web project must include Adobe Garamond + Gill Sans: https://fonts.adobe.com
ADOBE_FONTS_KIT_ID=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — use credentials from your host (shared hosting or VPS)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=looptrends
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# Shared hosting: public disk + `php artisan storage:link` unless STORAGE_USE_PUBLIC_PATH=true (Krystal zip / no symlink).
FILESYSTEM_DISK=public
# true = store PDFs/covers under public/uploads/ (no storage symlink). false = default storage/app/public + storage:link.
# Set true when mirroring a host that uses public/uploads (e.g. Krystal zip) so stream-pdf finds copied PDFs.
STORAGE_USE_PUBLIC_PATH=false
LIVEWIRE_TEMPORARY_FILE_UPLOAD_DISK=local

# sync = no background queue worker (typical on shared hosting)
QUEUE_CONNECTION=sync

# file = no extra cache DB tables required (works with storage/framework/cache permissions)
CACHE_STORE=file

# Mail — configure your SMTP provider
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@roberttodds.com"
MAIL_FROM_NAME="Robert Todd Trends"

# Google OAuth (Sign in with Google — Laravel Socialite)
# 1) GCP Console → APIs & Services → OAuth consent screen (External, add test users if Testing).
# 2) APIs & Services → Credentials → Create credentials → OAuth client ID → Web application.
# 3) Authorized JavaScript origins: https://your-production-domain.com
# 4) Authorized redirect URIs: https://your-production-domain.com/auth/google/callback
#    (add http://127.0.0.1:8443/auth/google/callback for local HTTPS if needed.)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

# Square Payments
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=production
SQUARE_APPLICATION_ID=

# Google Cloud Storage (optional — leave bucket empty to keep PDFs and covers on the local public disk)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_CLOUD_KEY_FILE=
# On GCP (e.g. Cloud Run) with a service account, you can leave GOOGLE_CLOUD_KEY_FILE empty.

VITE_APP_NAME="${APP_NAME}"
